<%- include('layouts/main', { title: title }) %>

    <div style="padding-top: 120px; padding-bottom: var(--spacing-4xl); min-height: 100vh;">
        <div class="container">
            <div style="display: grid; grid-template-columns: 300px 1fr; gap: var(--spacing-2xl);">
                <!-- Sidebar -->
                <%- include('partials/profile-sidebar', { activePage: activePage }) %>

                    <!-- Main Content -->
                    <div>
                        <div class="card" style="margin-bottom: var(--spacing-xl);">
                            <div class="card-body">
                                <h2 style="margin-bottom: var(--spacing-lg);">My Wishlist</h2>

                                <% if (wishlistItems && wishlistItems.length> 0) { %>
                                    <div
                                        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--spacing-lg);">
                                        <% wishlistItems.forEach(function(product) { %>
                                            <div class="product-card">
                                                <a href="/products/<%= product.id %>">
                                                    <div class="product-image">
                                                        <img src="<%= product.image %>" alt="<%= product.name %>"
                                                            onerror="this.onerror=null; this.src=''; this.style.background='linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)'; this.style.minHeight='200px';">
                                                        <button class="product-wishlist active"
                                                            data-product-id="<%= product.id %>"
                                                            data-product-name="<%= product.name %>">
                                                            <i class="fas fa-heart"></i>
                                                        </button>
                                                    </div>
                                                </a>
                                                <div class="product-info" style="padding: var(--spacing-md);">
                                                    <h4 style="margin-bottom: var(--spacing-xs);">
                                                        <a href="/products/<%= product.id %>"
                                                            style="color: inherit; text-decoration: none;">
                                                            <%= product.name %>
                                                        </a>
                                                    </h4>
                                                    <p
                                                        style="color: var(--color-gold); font-weight: 600; margin-bottom: var(--spacing-md);">
                                                        $<%= product.price.toLocaleString() %>
                                                    </p>
                                                    <div style="display: flex; gap: var(--spacing-sm);">
                                                        <a href="/products/<%= product.id %>"
                                                            class="btn btn-secondary btn-sm"
                                                            style="flex: 1; text-align: center;">View</a>
                                                        <form action="/cart/add" method="POST" style="flex: 1;">
                                                            <input type="hidden" name="productId"
                                                                value="<%= product.id %>">
                                                            <button type="submit" class="btn btn-primary btn-sm"
                                                                style="width: 100%;">Add to Cart</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }); %>
                                    </div>
                                    <% } else { %>
                                        <div
                                            style="text-align: center; padding: var(--spacing-3xl); background: var(--color-dark-gray); border-radius: var(--radius-lg); border: 1px solid var(--glass-border);">
                                            <div
                                                style="font-size: 4rem; margin-bottom: var(--spacing-lg); opacity: 0.5;">
                                                ❤️</div>
                                            <h3 style="margin-bottom: var(--spacing-sm);">Your wishlist is empty</h3>
                                            <p
                                                style="color: var(--color-light-gray); margin-bottom: var(--spacing-xl);">
                                                Start adding items you love to your wishlist!</p>
                                            <a href="/products" class="btn btn-primary">Continue Shopping</a>
                                        </div>
                                        <% } %>
                            </div>
                        </div>
                    </div>
            </div>
        </div>
    </div>

    <script src="/static/js/wishlist.js"></script>
    <%- include('partials/footer') %>