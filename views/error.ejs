<%- include('layouts/main', { title: title }) %>

    <div style="padding-top: 120px; min-height: 100vh; display: flex; align-items: center; justify-content: center;">
        <div class="container" style="max-width: 500px; text-align: center;">
            <div style="font-size: 6rem; margin-bottom: var(--spacing-lg);">😔</div>
            <h1 style="margin-bottom: var(--spacing-md);">
                <%= message || 'Error' %>
            </h1>
            <p class="text-muted" style="margin-bottom: var(--spacing-xl);">
                <%= typeof error !=='undefined' && error.message ? error.message
                    : 'Something went wrong. Please try again.' %>
            </p>
            <div style="display: flex; gap: var(--spacing-md); justify-content: center;">
                <a href="/" class="btn btn-primary">Go Home</a>
                <button onclick="history.back()" class="btn btn-secondary">Go Back</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>