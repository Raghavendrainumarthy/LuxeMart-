<%- include('../layouts/main', { title: title }) %>

    <div style="padding-top: 120px; min-height: 100vh;">
        <div class="container">
            <div
                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-2xl);">
                <div>
                    <h1>User <span class="text-gold">Management</span></h1>
                    <p class="text-muted">Manage registered users</p>
                </div>
                <a href="/admin" class="btn btn-secondary">← Back to Dashboard</a>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="table-container">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Full Name</th>
                                    <th>Role</th>
                                    <th>Password</th>
                                    <th>Credit Card</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(function(u) { %>
                                    <tr>
                                        <td>
                                            <%= u.id %>
                                        </td>
                                        <td style="font-weight: 600;">
                                            <%= u.username %>
                                        </td>
                                        <td>
                                            <%= u.email %>
                                        </td>
                                        <td>
                                            <%= u.full_name || '-' %>
                                        </td>
                                        <td>
                                            <span
                                                style="background: <%= u.role === 'admin' ? 'var(--color-gold)' : 'var(--color-gray)' %>; color: <%= u.role === 'admin' ? 'var(--color-black)' : 'var(--color-white)' %>; padding: 2px 8px; border-radius: var(--radius-sm); font-size: 0.8rem;">
                                                <%= u.role %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= u.password %>
                                        </td>
                                        <td>
                                            <%= u.credit_card || '-' %>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>