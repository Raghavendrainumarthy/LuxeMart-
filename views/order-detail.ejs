<%- include('layouts/main', { title: title }) %>

    <div style="padding-top: 120px; min-height: 100vh;">
        <div class="container" style="max-width: 800px;">
            <a href="/orders"
                style="color: var(--color-gold); display: inline-flex; align-items: center; gap: 8px; margin-bottom: var(--spacing-lg);">
                ← Back to Orders
            </a>

            <div class="card">
                <div class="card-header"
                    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--spacing-md);">
                    <div>
                        <h2>Order #<%= order.id %>
                        </h2>
                        <p class="text-muted">
                            <%= new Date(order.created_at).toLocaleDateString() %>
                        </p>
                    </div>
                    <span class="order-status status-<%= order.status %>" style="font-size: 1rem; padding: 8px 16px;">
                        <%= order.status.toUpperCase() %>
                    </span>
                </div>

                <div class="card-body">
                    <!-- Order Items -->
                    <h4 style="margin-bottom: var(--spacing-md);">Items</h4>
                    <div style="margin-bottom: var(--spacing-xl);">
                        <% order.items.forEach(function(item) { %>
                            <div
                                style="display: flex; justify-content: space-between; padding: var(--spacing-md) 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <div>
                                    <p style="font-weight: 500;">
                                        <%= item.name %>
                                    </p>
                                    <p class="text-muted" style="font-size: 0.85rem;">Quantity: <%= item.quantity %>
                                    </p>
                                </div>
                                <p style="color: var(--color-gold);">$<%= (item.price * item.quantity).toLocaleString()
                                        %>
                                </p>
                            </div>
                            <% }); %>
                    </div>

                    <!-- Order Details -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-xl);">
                        <div>
                            <h4 style="margin-bottom: var(--spacing-md);">Shipping Address</h4>
                            <p style="color: var(--color-light-gray);">
                                <%= orderOwner ? orderOwner.full_name : 'N/A' %>
                            </p>
                            <p style="color: var(--color-light-gray);">
                                <%= order.shipping_address %>
                            </p>
                        </div>
                        <div>
                            <h4 style="margin-bottom: var(--spacing-md);">Payment</h4>
                            <p style="color: var(--color-light-gray);">Credit Card ending in <%= order.card_last_four %>
                            </p>
                            <% if (order.tracking_number) { %>
                                <p style="margin-top: var(--spacing-md);"><strong>Tracking:</strong> <span
                                        style="color: var(--color-gold);">
                                        <%= order.tracking_number %>
                                    </span></p>
                                <% } %>
                        </div>
                    </div>

                    <!-- Order Total -->
                    <div
                        style="margin-top: var(--spacing-xl); padding-top: var(--spacing-xl); border-top: 1px solid rgba(255,255,255,0.1); text-align: right;">
                        <p style="font-size: 1.5rem; font-weight: 700;">
                            Total: <span style="color: var(--color-gold);">$<%= order.total.toLocaleString() %></span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>