<%- include('layouts/main', { title: title }) %>

    <section class="hero">
        <div class="hero-particles"></div>
        <!-- VULNERABLE: DOM-based XSS target - URL hash is injected here without sanitization -->
        <div id="welcome-message"
            style="position: absolute; top: 20px; left: 50%; transform: translateX(-50%); z-index: 100; background: var(--color-gray); padding: 10px 20px; border-radius: var(--radius-md); display: none;">
        </div>
        <div class="hero-content">
            <span class="hero-badge">Exclusive Collection 2024</span>
            <h1 class="hero-title">
                Discover <span class="text-gold">Luxury</span><br>
                Beyond Compare
            </h1>
            <p class="hero-subtitle">
                Immerse yourself in a world of exquisite craftsmanship. Curated collections from the world's most
                prestigious maisons, delivered to your door.
            </p>
            <div class="hero-cta">
                <a href="/products" class="btn btn-primary btn-lg">Explore Collection</a>
                <a href="/products?category=Watches" class="btn btn-secondary btn-lg">View Timepieces</a>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <div class="section-header">
                <h2>Featured <span class="text-gold">Products</span></h2>
                <p>Handpicked luxury items for the discerning collector</p>
            </div>

            <div class="products-grid">
                <% featuredProducts.forEach(function(product) { %>
                    <div class="product-card animate-fade-in" style="position: relative;">
                        <button
                            class="product-wishlist <%= (typeof wishlist !== 'undefined' && wishlist.has(product.id)) ? 'active' : '' %>"
                            data-product-id="<%= product.id %>" data-product-name="<%= product.name %>">
                            <i
                                class="<%= (typeof wishlist !== 'undefined' && wishlist.has(product.id)) ? 'fas' : 'far' %> fa-heart"></i>
                        </button>
                        <a href="/products/<%= product.id %>">
                            <div class="product-image">
                                <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                                    onerror="this.onerror=null; this.src=''; this.style.background='linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)'; this.style.minHeight='200px';">
                                <% if (product.original_price> product.price) { %>
                                    <span class="product-badge">Sale</span>
                                    <% } %>
                            </div>
                        </a>
                        <div class="product-info">
                            <span class="product-category">
                                <%= product.category %>
                            </span>
                            <h3 class="product-name">
                                <a href="/products/<%= product.id %>">
                                    <%= product.name %>
                                </a>
                            </h3>
                            <div class="product-rating">
                                <span class="stars">
                                    <%= '★' .repeat(Math.floor(product.rating)) %>
                                        <%= '☆' .repeat(5 - Math.floor(product.rating)) %>
                                </span>
                                <span class="text-muted">(<%= product.reviews_count || 0 %>)</span>
                            </div>
                            <div class="product-price">
                                <span class="price-current">$<%= product.price.toLocaleString() %></span>
                                <% if (product.original_price> product.price) { %>
                                    <span class="price-original">$<%= product.original_price.toLocaleString() %></span>
                                    <% } %>
                            </div>
                        </div>
                        <div class="product-actions">
                            <form action="/cart/add" method="POST">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <button type="submit" class="btn btn-add-cart">Add to Cart</button>
                            </form>
                        </div>
                    </div>
                    <% }); %>
            </div>
        </div>
    </section>

    <section class="section" style="background: var(--color-dark);">
        <div class="container">
            <div class="section-header">
                <h2>New <span class="text-gold">Arrivals</span></h2>
                <p>Just landed - the latest additions to our collection</p>
            </div>

            <div class="products-grid">
                <% newArrivals.forEach(function(product) { %>
                    <div class="product-card animate-fade-in" style="position: relative;">
                        <button
                            class="product-wishlist <%= (typeof wishlist !== 'undefined' && wishlist.has(product.id)) ? 'active' : '' %>"
                            data-product-id="<%= product.id %>" data-product-name="<%= product.name %>">
                            <i
                                class="<%= (typeof wishlist !== 'undefined' && wishlist.has(product.id)) ? 'fas' : 'far' %> fa-heart"></i>
                        </button>
                        <a href="/products/<%= product.id %>">
                            <div class="product-image">
                                <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                                    onerror="this.onerror=null; this.src=''; this.style.background='linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)'; this.style.minHeight='200px';">
                                <span class="product-badge" style="background: var(--color-success);">New</span>
                            </div>
                        </a>
                        <div class="product-info">
                            <span class="product-category">
                                <%= product.category %>
                            </span>
                            <h3 class="product-name">
                                <a href="/products/<%= product.id %>">
                                    <%= product.name %>
                                </a>
                            </h3>
                            <div class="product-price">
                                <span class="price-current">$<%= product.price.toLocaleString() %></span>
                            </div>
                        </div>
                        <div class="product-actions">
                            <form action="/cart/add" method="POST">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <button type="submit" class="btn btn-add-cart">Add to Cart</button>
                            </form>
                        </div>
                    </div>
                    <% }); %>
            </div>

            <div style="text-align: center; margin-top: var(--spacing-2xl);">
                <a href="/products" class="btn btn-primary btn-lg">View All Products</a>
            </div>
        </div>
    </section>

    <section class="section features-section">
        <div class="container">
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5">
                            <path
                                d="M5 18H19M5 18C5 19.1046 4.10457 20 3 20C1.89543 20 1 19.1046 1 18C1 16.8954 1.89543 16 3 16C4.10457 16 5 16.8954 5 18ZM19 18C19 19.1046 18.1046 20 17 20C15.8954 20 15 19.1046 15 18C15 16.8954 15.8954 16 17 16C18.1046 16 19 16.8954 19 18ZM19 18H21V11L17 7H13V18M5 18V7C5 5.89543 5.89543 5 7 5H11V18" />
                        </svg>
                    </div>
                    <h4>Complimentary Shipping</h4>
                    <p class="text-muted">Free worldwide delivery on orders over $500</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7C7 4.23858 9.23858 2 12 2C14.7614 2 17 4.23858 17 7V11" />
                        </svg>
                    </div>
                    <h4>Secure Transactions</h4>
                    <p class="text-muted">End-to-end encrypted payment processing</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5">
                            <path
                                d="M3 9L12 2L21 9V20C21 20.5304 20.7893 21.0391 20.4142 21.4142C20.0391 21.7893 19.5304 22 19 22H5C4.46957 22 3.96086 21.7893 3.58579 21.4142C3.21071 21.0391 3 20.5304 3 20V9Z" />
                            <polyline points="9,22 9,12 15,12 15,22" />
                        </svg>
                    </div>
                    <h4>Hassle-Free Returns</h4>
                    <p class="text-muted">30-day no-questions-asked return policy</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5">
                            <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" />
                            <path d="M9 12L11 14L15 10" />
                        </svg>
                    </div>
                    <h4>Authenticity Guaranteed</h4>
                    <p class="text-muted">100% genuine luxury products certified</p>
                </div>
            </div>
        </div>
    </section>

    <script src="/static/js/wishlist.js"></script>
    <%- include('partials/footer') %>