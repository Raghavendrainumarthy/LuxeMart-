<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'LuxeMart - Premium Shopping' %>
    </title>
    <!-- VULNERABLE: Web Cache Poisoning - canonical URL uses potentially poisoned host header -->
    <link rel="canonical" href="http://<%= hostHeader %><%= typeof path !== 'undefined' ? path : '' %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/static/css/style.css">
</head>

<body>
    <!-- Page Loading Overlay -->
    <div id="pageLoader" class="page-loader">
        <div class="loader-progress"></div>
        <div class="loader-content">
            <div class="loader-spinner"></div>
            <div class="loader-text">Loading...</div>
        </div>
    </div>

    <style>
        .page-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 10, 12, 0.98);
            z-index: 99999;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.4s ease, visibility 0.4s ease;
            backdrop-filter: blur(8px);
        }

        .page-loader.active {
            opacity: 1;
            visibility: visible;
        }

        .loader-progress {
            position: absolute;
            top: 0;
            left: 0;
            height: 2px;
            background: var(--gradient-gold);
            width: 0%;
            transition: width 0.3s ease;
            box-shadow: 0 0 15px var(--color-gold);
        }

        .page-loader.active .loader-progress {
            animation: progressBar 2.5s cubic-bezier(0.1, 0.5, 0.5, 1) forwards;
        }

        @keyframes progressBar {
            0% {
                width: 0%;
            }

            30% {
                width: 40%;
            }

            60% {
                width: 70%;
            }

            100% {
                width: 98%;
            }
        }

        .loader-content {
            text-align: center;
        }

        .loader-spinner {
            width: 60px;
            height: 60px;
            border: 2px solid rgba(201, 169, 98, 0.1);
            border-top: 2px solid var(--color-gold);
            border-radius: 50%;
            animation: spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
            margin: 0 auto 24px;
            box-shadow: 0 0 20px rgba(201, 169, 98, 0.1);
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .loader-text {
            color: var(--color-gold);
            font-family: var(--font-display);
            font-size: 1.1rem;
            letter-spacing: 5px;
            text-transform: uppercase;
            font-weight: 500;
            opacity: 0.9;
        }
    </style>

    <script>
        // Show loader on page navigation
        document.addEventListener('click', function (e) {
            const link = e.target.closest('a');
            // Don't trigger loader for wishlist button clicks
            if (e.target.closest('.product-wishlist')) return;
            if (link && link.href && !link.href.startsWith('javascript:') &&
                !link.href.startsWith('#') && !link.target &&
                !link.hasAttribute('download') && link.host === window.location.host &&
                link.pathname !== window.location.pathname) {
                e.preventDefault();
                const loader = document.getElementById('pageLoader');
                loader.classList.add('active');
                setTimeout(() => {
                    window.location.href = link.href;
                }, 400);
            }
        });

        // Show loader on form submit
        document.addEventListener('submit', function (e) {
            const form = e.target;
            if (!form.hasAttribute('data-no-loader')) {
                const loader = document.getElementById('pageLoader');
                loader.classList.add('active');
            }
        });

        // Hide loader when page loads
        window.addEventListener('load', function () {
            const loader = document.getElementById('pageLoader');
            loader.classList.remove('active');
        });

        // Fail-safe: hide loader after 5 seconds no matter what
        setTimeout(function () {
            const loader = document.getElementById('pageLoader');
            if (loader) loader.classList.remove('active');
        }, 5000);

        // Handle back/forward navigation
        window.addEventListener('pageshow', function (e) {
            if (e.persisted) {
                const loader = document.getElementById('pageLoader');
                loader.classList.remove('active');
            }
        });

        // VULNERABLE: DOM-based XSS via URL hash
        // Example payload: http://localhost:3000/#<img src=x onerror=alert('XSS')>
        (function () {
            const hash = decodeURIComponent(window.location.hash.substring(1));
            if (hash) {
                const welcomeDiv = document.getElementById('welcome-message');
                if (welcomeDiv) {
                    welcomeDiv.style.display = 'block';
                    welcomeDiv.innerHTML = 'Welcome, ' + hash + '!';
                }
            }
        })();
    </script>

    <%- include('../partials/header') %>
        <main>