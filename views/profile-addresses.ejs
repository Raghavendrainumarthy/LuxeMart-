<%- include('layouts/main', { title: title }) %>

    <div style="padding-top: 120px; padding-bottom: var(--spacing-4xl); min-height: 100vh;">
        <div class="container">
            <div style="display: grid; grid-template-columns: 300px 1fr; gap: var(--spacing-2xl);">
                <!-- Sidebar -->
                <%- include('partials/profile-sidebar', { activePage: activePage }) %>

                    <!-- Main Content -->
                    <div>
                        <div class="card" style="margin-bottom: var(--spacing-xl);">
                            <div class="card-body">
                                <h2 style="margin-bottom: var(--spacing-lg);">Manage Addresses</h2>

                                <div style="display: grid; gap: var(--spacing-lg);">
                                    <!-- Add New Address Button -->
                                    <button type="button" class="btn btn-primary" style="width: fit-content;" onclick="document.getElementById('addAddressDialog').style.display='flex'">
                                        + Add New Address
                                    </button>

                                    <!-- Addresses List -->
                                    <% if (addresses && addresses.length > 0) { %>
                                        <% addresses.forEach(address => { %>
                                        <!-- Address Card -->
                                        <div style="background: var(--color-gray); padding: var(--spacing-lg); border-radius: var(--radius-lg); border: 1px solid var(--glass-border);">
                                            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: var(--spacing-md);">
                                                <span style="background: var(--color-gold); color: var(--color-black); padding: 4px 12px; border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 600;">
                                                    <%= address.label %>
                                                </span>
                                                <div style="display: flex; gap: var(--spacing-sm);">
                                                    <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('editAddressDialog-<%= address.id %>').style.display='flex'">Edit</button>
                                                    <form action="/profile/addresses/delete/<%= address.id %>" method="POST" style="margin:0;" onsubmit="return confirm('Are you sure you want to delete this address?');">
                                                        <button type="submit" class="btn btn-secondary btn-sm" style="color: var(--color-error);">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                            <h4 style="margin-bottom: var(--spacing-sm);">
                                                <%= address.full_name %>
                                            </h4>
                                            <p style="color: var(--color-light-gray); line-height: 1.6;">
                                                <%= address.address_line %>
                                            </p>
                                            <% if (address.phone) { %>
                                            <p style="margin-top: var(--spacing-sm); color: var(--color-light-gray);">
                                                📞 <%= address.phone %>
                                            </p>
                                            <% } %>
                                        </div>

                                        <!-- Edit Dialog for this address -->
                                        <div id="editAddressDialog-<%= address.id %>" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center; backdrop-filter: blur(5px);">
                                            <div style="border:1px solid var(--glass-border); border-radius:var(--radius-lg); background:var(--color-dark); color:white; padding:var(--spacing-xl); width:90%; max-width:500px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--spacing-lg);">
                                                    <h3>Edit Address</h3>
                                                    <button type="button" onclick="document.getElementById('editAddressDialog-<%= address.id %>').style.display='none'" style="background:none; border:none; color:white; font-size:1.5rem; cursor:pointer;">&times;</button>
                                                </div>
                                                <form action="/profile/addresses/edit/<%= address.id %>" method="POST" style="display:flex; flex-direction:column; gap:var(--spacing-md);">
                                                    <div>
                                                        <label style="display:block; margin-bottom:var(--spacing-xs);">Label</label>
                                                        <input type="text" name="label" class="form-control" value="<%= address.label %>" required style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px;">
                                                    </div>
                                                    <div>
                                                        <label style="display:block; margin-bottom:var(--spacing-xs);">Full Name</label>
                                                        <input type="text" name="full_name" class="form-control" value="<%= address.full_name %>" required style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px;">
                                                    </div>
                                                    <div>
                                                        <label style="display:block; margin-bottom:var(--spacing-xs);">Address Line</label>
                                                        <textarea name="address_line" class="form-control" required style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px; min-height:80px;"><%= address.address_line %></textarea>
                                                    </div>
                                                    <div>
                                                        <label style="display:block; margin-bottom:var(--spacing-xs);">Phone</label>
                                                        <input type="text" name="phone" class="form-control" value="<%= address.phone %>" style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px;">
                                                    </div>
                                                    <div style="display:flex; justify-content:flex-end; gap:var(--spacing-sm); margin-top:var(--spacing-md);">
                                                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('editAddressDialog-<%= address.id %>').style.display='none'">Cancel</button>
                                                        <button type="submit" class="btn btn-primary">Save Changes</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>

                                        <% }) %>
                                    <% } else { %>
                                        <!-- Empty state message if no address -->
                                        <div style="text-align: center; padding: var(--spacing-2xl); color: var(--color-light-gray);">
                                            <p>No saved addresses. Add an address for faster checkout.</p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Add New Address Dialog -->
                    <div id="addAddressDialog" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center; backdrop-filter: blur(5px);">
                        <div style="border:1px solid var(--glass-border); border-radius:var(--radius-lg); background:var(--color-dark); color:white; padding:var(--spacing-xl); width:90%; max-width:500px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--spacing-lg);">
                                <h3>Add New Address</h3>
                                <button type="button" onclick="document.getElementById('addAddressDialog').style.display='none'" style="background:none; border:none; color:white; font-size:1.5rem; cursor:pointer;">&times;</button>
                            </div>
                            <form action="/profile/addresses/add" method="POST" style="display:flex; flex-direction:column; gap:var(--spacing-md);">
                                <div>
                                    <label style="display:block; margin-bottom:var(--spacing-xs);">Label (e.g., HOME, WORK)</label>
                                    <input type="text" name="label" class="form-control" placeholder="HOME" required style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px;">
                                </div>
                                <div>
                                    <label style="display:block; margin-bottom:var(--spacing-xs);">Full Name</label>
                                    <input type="text" name="full_name" class="form-control" value="<%= user.full_name || user.username %>" required style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px;">
                                </div>
                                <div>
                                    <label style="display:block; margin-bottom:var(--spacing-xs);">Address Line</label>
                                    <textarea name="address_line" class="form-control" required style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px; min-height:80px;"></textarea>
                                </div>
                                <div>
                                    <label style="display:block; margin-bottom:var(--spacing-xs);">Phone</label>
                                    <input type="text" name="phone" class="form-control" value="<%= user.phone || '' %>" style="width:100%; background:var(--color-gray); border:1px solid var(--glass-border); color:white; padding:8px; border-radius:4px;">
                                </div>
                                <div style="display:flex; justify-content:flex-end; gap:var(--spacing-sm); margin-top:var(--spacing-md);">
                                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('addAddressDialog').style.display='none'">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Save Address</button>
                                </div>
                            </form>
                        </div>
                    </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>