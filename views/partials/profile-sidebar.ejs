<div style="display: flex; flex-direction: column; gap: var(--spacing-lg);">
    <!-- User Card -->
    <div class="card">
        <div class="card-body" style="text-align: center; padding: 24px;">
            <div style="position: relative; display: inline-block;">
                <div id="profile-avatar"
                    style="width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; font-size: 2.5rem; overflow: hidden; border: 3px solid var(--color-gold); background: var(--gradient-gold); box-shadow: var(--shadow-glow); color: var(--color-black); font-weight: 700;">
                    <%= user.full_name ? user.full_name.charAt(0).toUpperCase() :
                        user.username.charAt(0).toUpperCase() %>
                </div>
            </div>
            <h3 style="margin-top: var(--spacing-md); font-family: var(--font-display); color: var(--color-white);">
                <!-- VULNERABLE: Stored XSS - user name displayed without sanitization -->
                <%- user.full_name || user.username %>
            </h3>
            <p class="text-muted" style="font-size: 0.85rem;">
                <%= user.email %>
            </p>
            <span
                style="display: inline-block; background: <%= user.role === 'admin' ? 'var(--color-gold)' : 'var(--color-gray)' %>; color: <%= user.role === 'admin' ? 'var(--color-black)' : 'var(--color-white)' %>; padding: 4px 12px; border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 600; margin-top: var(--spacing-sm); letter-spacing: 0.5px;">
                <%= user.role.toUpperCase() %>
            </span>
        </div>
    </div>

    <!-- Account Settings Section -->
    <div class="card"
        style="background: var(--color-dark-gray); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--glass-border);">
        <div
            style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.02);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-gold)">
                <path
                    d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
            <span
                style="font-size: 0.75rem; font-weight: 600; color: var(--color-light-gray); letter-spacing: 1px; text-transform: uppercase;">Account
                Settings</span>
        </div>
        <nav style="display: flex; flex-direction: column;">
            <a href="/user/profile"
                style="display: block; padding: 14px 20px; color: <%= activePage === 'profile' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'profile' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'profile' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'profile' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">Profile
                Information</a>
            <a href="/profile/addresses"
                style="display: block; padding: 14px 20px; color: <%= activePage === 'addresses' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'addresses' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'addresses' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'addresses' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">Manage
                Addresses</a>
        </nav>
    </div>

    <!-- Payments Section -->
    <div class="card"
        style="background: var(--color-dark-gray); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--glass-border);">
        <div
            style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.02);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-gold)">
                <path
                    d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" />
            </svg>
            <span
                style="font-size: 0.75rem; font-weight: 600; color: var(--color-light-gray); letter-spacing: 1px; text-transform: uppercase;">Payments</span>
        </div>
        <nav style="display: flex; flex-direction: column;">
            <a href="/profile/gift-cards"
                style="display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; color: <%= activePage === 'gift-cards' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'gift-cards' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'gift-cards' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'gift-cards' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">
                <span>Gift Cards</span>
            </a>
            <a href="/profile/saved-cards"
                style="display: block; padding: 14px 20px; color: <%= activePage === 'saved-cards' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'saved-cards' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'saved-cards' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'saved-cards' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">Saved
                Cards</a>
        </nav>
    </div>

    <!-- My Stuff Section -->
    <div class="card"
        style="background: var(--color-dark-gray); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--glass-border);">
        <div
            style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.02);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-gold)">
                <path
                    d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" />
            </svg>
            <span
                style="font-size: 0.75rem; font-weight: 600; color: var(--color-light-gray); letter-spacing: 1px; text-transform: uppercase;">My
                Stuff</span>
        </div>
        <nav style="display: flex; flex-direction: column;">
            <a href="/orders"
                style="display: block; padding: 14px 20px; color: <%= activePage === 'orders' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'orders' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'orders' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'orders' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">My
                Orders</a>
            <a href="/cart"
                style="display: block; padding: 14px 20px; color: <%= activePage === 'cart' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'cart' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'cart' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'cart' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">My
                Cart</a>
            <a href="/wishlist"
                style="display: block; padding: 14px 20px; color: <%= activePage === 'wishlist' ? 'var(--color-gold)' : 'var(--color-off-white)' %>; font-size: 0.9rem; <%= activePage === 'wishlist' ? 'font-weight: 500;' : '' %> text-decoration: none; background: <%= activePage === 'wishlist' ? 'rgba(201, 169, 98, 0.1)' : 'transparent' %>; border-left: 3px solid <%= activePage === 'wishlist' ? 'var(--color-gold)' : 'transparent' %>; transition: all 0.2s;">My
                Wishlist</a>
        </nav>
    </div>

    <!-- Logout -->
    <div class="card"
        style="margin-top: var(--spacing-md); background: var(--color-dark-gray); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--glass-border); margin-bottom: var(--spacing-lg);">
        <a href="/logout"
            style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; color: var(--color-error); font-size: 0.9rem; text-decoration: none; transition: all 0.2s; background: rgba(239, 68, 68, 0.05);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path
                    d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
            </svg>
            <span style="font-weight: 500;">Logout</span>
        </a>
    </div>
</div>