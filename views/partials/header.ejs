<header class="header">
    <div class="container">
        <nav class="nav">
            <a href="/" class="logo">◆ Luxe<span class="text-gold">Mart</span></a>

            <div class="nav-links">
                <a href="/products" class="nav-link">Shop All</a>
                <a href="/products?category=Watches" class="nav-link">Timepieces</a>
                <a href="/products?category=Bags" class="nav-link">Leather</a>
                <a href="/products?category=Jewelry" class="nav-link">Jewelry</a>
            </div>

            <div class="nav-actions">
                <form action="/products" method="GET" class="header-search" autocomplete="off">
                    <input type="text" name="search" placeholder="Search collection..." class="search-input"
                        autocomplete="off">
                    <button type="submit" class="search-btn" aria-label="Search">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <path d="M21 21l-4.35-4.35" />
                        </svg>
                    </button>
                </form>

                <a href="/wishlist" class="nav-icon wishlist-link" aria-label="Wishlist" style="color: inherit;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path
                            d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
                    </svg>
                    <% if (typeof wishlist !=='undefined' && wishlist.size> 0) { %>
                        <span class="cart-count">
                            <%= wishlist.size %>
                        </span>
                        <% } %>
                </a>

                <a href="/cart" class="nav-icon cart-link" aria-label="Shopping bag">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 01-8 0" />
                    </svg>
                    <% if (typeof cartCount !=='undefined' && cartCount> 0) { %>
                        <span class="cart-count">
                            <%= cartCount %>
                        </span>
                        <% } %>
                </a>

                <% if (typeof user !=='undefined' && user) { %>
                    <div class="user-dropdown-container">
                        <button class="user-btn" aria-label="Account menu">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </button>
                        <div class="user-dropdown">
                            <div class="dropdown-header">
                                <!-- VULNERABLE: Stored XSS - user name in header -->
                                <strong>
                                    <%- user.full_name || user.username %>
                                </strong>
                                <span class="text-muted">
                                    <%= user.email %>
                                </span>
                            </div>
                            <div class="dropdown-divider"></div>
                            <a href="/user/profile" class="dropdown-item">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                                My Profile
                            </a>
                            <a href="/orders" class="dropdown-item">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
                                </svg>
                                Order History
                            </a>
                            <% if (user.role==='admin' ) { %>
                                <a href="/admin" class="dropdown-item" style="color: var(--color-gold);">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <circle cx="12" cy="12" r="3" />
                                        <path
                                            d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z" />
                                    </svg>
                                    Admin Panel
                                </a>
                                <% } %>
                                    <div class="dropdown-divider"></div>
                                    <a href="/logout" class="dropdown-item logout-link">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2">
                                            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
                                            <polyline points="16,17 21,12 16,7" />
                                            <line x1="21" y1="12" x2="9" y2="12" />
                                        </svg>
                                        Sign Out
                                    </a>
                        </div>
                    </div>
                    <% } else { %>
                        <a href="/login" class="btn btn-primary btn-sm">Sign In</a>
                        <% } %>
            </div>
        </nav>
    </div>
</header>