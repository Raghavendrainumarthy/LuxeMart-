<%- include('layouts/main', { title: title }) %>

    <div style="padding-top: 120px; min-height: 100vh;">
        <div class="container" style="max-width: 600px; text-align: center;">
            <div style="font-size: 5rem; margin-bottom: var(--spacing-lg);">✅</div>
            <h1 style="margin-bottom: var(--spacing-md);">Order <span class="text-gold">Confirmed!</span></h1>
            <p class="text-muted" style="font-size: 1.1rem; margin-bottom: var(--spacing-2xl);">
                Thank you for your purchase. Your order has been placed successfully.
            </p>

            <div class="card" style="margin-bottom: var(--spacing-2xl);">
                <div class="card-body" style="text-align: left;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: var(--spacing-md);">
                        <span class="text-muted">Order Number</span>
                        <strong style="color: var(--color-gold);">
                            <%= trackingNumber %>
                        </strong>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span class="text-muted">Total Amount</span>
                        <strong>$<%= total.toLocaleString() %></strong>
                    </div>
                </div>
            </div>

            <p class="text-muted" style="margin-bottom: var(--spacing-xl);">
                A confirmation email has been sent to your email address.
            </p>

            <div style="display: flex; gap: var(--spacing-md); justify-content: center;">
                <a href="/orders" class="btn btn-primary">View Orders</a>
                <a href="/products" class="btn btn-secondary">Continue Shopping</a>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>