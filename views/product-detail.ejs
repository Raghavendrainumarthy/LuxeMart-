<%- include('layouts/main', { title: title }) %>

    <div style="padding-top: 120px; min-height: 100vh;">
        <div class="container">
            <a href="/products"
                style="color: var(--color-gold); display: inline-flex; align-items: center; gap: 8px; margin-bottom: var(--spacing-lg);">
                ← Back to Products
            </a>

            <div class="product-detail">
                <div class="product-gallery">
                    <div class="product-main-image">
                        <img src="<%= product.image %>" alt="<%= product.name %>"
                            onerror="this.onerror=null; this.style.display='none'; this.parentElement.innerHTML='<div style=\'width:100%;height:400px;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);display:flex;align-items:center;justify-content:center;border-radius:var(--radius-lg);\'><span style=\'font-size:4rem;opacity:0.3;\'>📦</span></div>';">
                    </div>
                </div>

                <div class="product-details">
                    <span class="product-category">
                        <%= product.category %>
                    </span>
                    <h1>
                        <%= product.name %>
                    </h1>

                    <div class="product-rating" style="margin: var(--spacing-md) 0;">
                        <span class="stars">
                            <%= '★' .repeat(Math.floor(product.rating)) %>
                                <%= '☆' .repeat(5 - Math.floor(product.rating)) %>
                        </span>
                        <span class="text-muted">(<%= product.reviews_count || 0 %> reviews)</span>
                    </div>

                    <div class="product-price" style="font-size: 1.5rem; margin: var(--spacing-lg) 0;">
                        <span class="price-current">$<%= product.price.toLocaleString() %></span>
                        <% if (product.original_price> product.price) { %>
                            <span class="price-original">$<%= product.original_price.toLocaleString() %></span>
                            <% } %>
                    </div>

                    <p style="color: var(--color-light-gray); line-height: 1.7; margin-bottom: var(--spacing-xl);">
                        <%= product.description %>
                    </p>

                    <form action="/cart/add" method="POST"
                        style="display: flex; gap: var(--spacing-md); align-items: center; margin-bottom: var(--spacing-xl);">
                        <input type="hidden" name="productId" value="<%= product.id %>">
                        <div class="quantity-selector">
                            <button type="button" onclick="this.parentNode.querySelector('input').stepDown()">-</button>
                            <input type="number" name="quantity" value="1" min="1" max="10">
                            <button type="button" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
                        <button type="button"
                            class="product-wishlist detail-wishlist <%= (typeof wishlist !== 'undefined' && wishlist.has(product.id)) ? 'active' : '' %>"
                            data-product-id="<%= product.id %>" data-product-name="<%= product.name %>"
                            style="position: static; opacity: 1; transform: none; width: 52px; height: 52px; flex-shrink: 0;">
                            <i
                                class="<%= (typeof wishlist !== 'undefined' && wishlist.has(product.id)) ? 'fas' : 'far' %> fa-heart"></i>
                        </button>
                    </form>

                    <div
                        style="padding: var(--spacing-lg); background: var(--color-gray); border-radius: var(--radius-md);">
                        <p style="font-size: 0.9rem;"><span style="color: var(--color-success);">✓</span> In Stock (<%=
                                product.stock %> available)</p>
                        <p style="font-size: 0.9rem; margin-top: var(--spacing-sm);"><span
                                style="color: var(--color-gold);">🚚</span> Free shipping on orders over $500</p>
                    </div>
                </div>
            </div>

            <!-- Reviews Section -->
            <div class="reviews-section" style="margin-top: var(--spacing-3xl);">
                <h2 style="margin-bottom: var(--spacing-xl);">Customer <span class="text-gold">Reviews</span></h2>

                <% if (user) { %>
                    <div class="card" style="margin-bottom: var(--spacing-xl);">
                        <div class="card-header">
                            <h4>Write a Review</h4>
                        </div>
                        <div class="card-body">
                            <form action="/products/<%= product.id %>/review" method="POST">
                                <div class="form-group">
                                    <label class="form-label">Rating</label>
                                    <select name="rating" class="form-input" required>
                                        <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                                        <option value="4">⭐⭐⭐⭐ Good</option>
                                        <option value="3">⭐⭐⭐ Average</option>
                                        <option value="2">⭐⭐ Poor</option>
                                        <option value="1">⭐ Terrible</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Your Review</label>
                                    <textarea name="comment" class="form-input" rows="4"
                                        placeholder="Share your experience..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Submit Review</button>
                            </form>
                        </div>
                    </div>
                    <% } else { %>
                        <div class="card" style="margin-bottom: var(--spacing-xl);">
                            <div class="card-body" style="text-align: center;">
                                <p class="text-muted">Please <a href="/login"
                                        style="color: var(--color-gold);">login</a> to leave a review</p>
                            </div>
                        </div>
                        <% } %>

                            <div class="reviews-list" style="display: flex; flex-direction: column; gap: 20px;">
                                <% if (reviews.length > 0) { %>
                                    <% reviews.forEach(function(review) { %>
                                        <div style="
                                            background: linear-gradient(135deg, rgba(30,30,35,0.9) 0%, rgba(25,25,30,0.95) 100%);
                                            border: 1px solid rgba(201,169,98,0.12);
                                            border-left: 3px solid rgba(201,169,98,0.5);
                                            border-radius: 12px;
                                            padding: 24px 28px;
                                            transition: all 0.3s ease;
                                        " onmouseover="this.style.borderLeftColor='rgba(201,169,98,0.9)'; this.style.boxShadow='0 8px 32px rgba(0,0,0,0.3)'"
                                           onmouseout="this.style.borderLeftColor='rgba(201,169,98,0.5)'; this.style.boxShadow='none'">

                                            <!-- Top row: username + stars on left, date + delete on right -->
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
                                                <div style="display: flex; align-items: center; gap: 16px;">
                                                    <span style="
                                                        font-weight: 700;
                                                        font-size: 0.95rem;
                                                        color: var(--color-gold);
                                                        letter-spacing: 0.5px;
                                                    "><%= review.username %></span>
                                                    <span style="font-size: 0.85rem; letter-spacing: 1px; color: #d4a84b;">
                                                        <%= '★'.repeat(review.rating) %><span style="color: rgba(255,255,255,0.15);"><%= '★'.repeat(5 - review.rating) %></span>
                                                    </span>
                                                </div>
                                                <div style="display: flex; align-items: center; gap: 12px; flex-shrink: 0;">
                                                    <span style="font-size: 0.78rem; color: rgba(255,255,255,0.35); font-weight: 400;">
                                                        <%= new Date(review.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                                    </span>
                                                    <% if (user && (user.id === review.user_id || user.role === 'admin')) { %>
                                                        <form action="/products/<%= product.id %>/review/delete/<%= review.id %>"
                                                            method="POST" style="margin:0; line-height:0;"
                                                            onsubmit="return confirm('Delete this review?')">
                                                            <button type="submit" title="Delete Review" style="
                                                                width: 30px; height: 30px;
                                                                border-radius: 8px;
                                                                border: 1px solid rgba(239,68,68,0.25);
                                                                background: rgba(239,68,68,0.06);
                                                                color: #f87171;
                                                                cursor: pointer;
                                                                display: flex; align-items: center; justify-content: center;
                                                                font-size: 0.72rem;
                                                                padding: 0;
                                                                transition: all 0.2s ease;
                                                            " onmouseover="this.style.background='rgba(239,68,68,0.18)'; this.style.borderColor='rgba(239,68,68,0.5)'"
                                                               onmouseout="this.style.background='rgba(239,68,68,0.06)'; this.style.borderColor='rgba(239,68,68,0.25)'">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </div>

                                            <!-- Comment -->
                                            <div style="
                                                color: rgba(255,255,255,0.75);
                                                font-size: 0.92rem;
                                                line-height: 1.7;
                                                padding-left: 2px;
                                                font-style: italic;
                                            ">
                                                <%- review.comment %>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div style="
                                        text-align: center;
                                        padding: 48px 24px;
                                        background: rgba(30,30,35,0.5);
                                        border: 1px dashed rgba(201,169,98,0.2);
                                        border-radius: 12px;
                                    ">
                                        <p style="color: rgba(255,255,255,0.4); font-size: 0.95rem;">No reviews yet. Be the first to share your experience.</p>
                                    </div>
                                <% } %>
                            </div>
            </div>

            <!-- Related Products -->
            <% if (relatedProducts.length> 0) { %>
                <div style="margin-top: var(--spacing-3xl);">
                    <h2 style="margin-bottom: var(--spacing-xl);">Related <span class="text-gold">Products</span></h2>
                    <div class="products-grid">
                        <% relatedProducts.forEach(function(p) { %>
                            <div class="product-card">
                                <a href="/products/<%= p.id %>">
                                    <div class="product-image">
                                        <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
                                    </div>
                                </a>
                                <div class="product-info">
                                    <span class="product-category">
                                        <%= p.category %>
                                    </span>
                                    <h3 class="product-name"><a href="/products/<%= p.id %>">
                                            <%= p.name %>
                                        </a></h3>
                                    <div class="product-price">
                                        <span class="price-current">$<%= p.price.toLocaleString() %></span>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                </div>
                <% } %>
        </div>
    </div>

    <script src="/static/js/wishlist.js"></script>
    <%- include('partials/footer') %>